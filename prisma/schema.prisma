generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Story {
  id         Int      @id @default(autoincrement())
  title      String   @default("따뜻한 기억의 기록")
  author     String
  content    String
  beforeImg  String
  afterImg   String
  likes      Int      @default(0)
  isCuration Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model User {
  id          Int      @id @default(autoincrement())
  firebaseUid String   @unique
  email       String?
  tokens      Int      @default(0) // Default 0 tokens upon signup
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
